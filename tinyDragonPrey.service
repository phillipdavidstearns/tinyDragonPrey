[Unit]
Description=tinyDragonPrey
After=network.target

[Service]
Type=simple
ExecStartPre=/bin/sleep 5
ExecStart=/usr/local/src/venv/bin/python3 /usr/local/src/tinyDragonPrey/tinyDragonPrey.py
Restart=on-success
RestartPreventExitStatus=SIGTERM SIGKILL
RestartSec=5

[Install]
WantedBy=multi-user.target